# Hostname served by Caddy (and used in deploy.sh output)
GASOLINERAS_HOST=gasolineras.ojoalprecio.com

# Name of the external Docker network your shared Caddy is on
# (docker inspect <caddy-container> --format '{{json .NetworkSettings.Networks}}')
PROXY_NETWORK=cloud_default

# Pin a specific image tag (default: latest)
# GASOLINERAS_TAG=v1.0.0

# Override compose file (default: docker-compose.yml = shared Caddy)
# GASOLINERAS_COMPOSE=docker-compose.standalone.yml
