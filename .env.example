# Hostname served by Caddy (and used in deploy.sh output)
GASOLINERAS_HOST=gasolineras.ojoalprecio.com

# Pin a specific image tag (default: latest)
# GASOLINERAS_TAG=v1.0.0

# Shared-Caddy mode: name of the external Docker network your Caddy is on
# PROXY_NETWORK=caddy_network

# Which compose file deploy.sh uses (default: docker-compose.shared.yml)
# GASOLINERAS_COMPOSE=docker-compose.yml
